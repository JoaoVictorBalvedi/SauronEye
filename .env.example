# Telegram
BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_API_URL=https://api.telegram.org/bot  # custom endpoint/mirror (optional)
# TELEGRAM_PROXY_URL=                           # proxy for Telegram traffic (optional)

# Webhook
# On HF Spaces this is auto-detected from SPACE_ID.
# For local dev, set to your ngrok/tunnel URL + /webhook:
# WEBHOOK_URL=https://your-ngrok.ngrok.io/webhook

# Ollama
LLM_MODEL=llama3.2

# Google Sheets — use EITHER file path OR JSON content
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# GOOGLE_SERVICE_ACCOUNT={"type":"service_account",...}

# Service account email (shown to users so they can share their sheet)
SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
